# Production-like configuration for docker-compose.prod.yml (ADR 0017).
# Copy to .env.prod and fill in real values, then:
#   docker-compose --env-file .env.prod -f docker-compose.prod.yml up --build
# .env.prod is gitignored — never commit real secrets (ADR 0009).

# Environment name. Anything other than "local" enforces strong secrets
# (validate_production_secrets). Use "staging" or "production".
PULSEGRAPH_ENV=production

# Postgres password for the bundled db service (and the app's DATABASE_URL).
POSTGRES_PASSWORD=change-me

# JWT signing key — MUST be overridden with a strong value of at least 32
# bytes, or the API and worker refuse to start (ADR 0009/0021). This sentinel
# is deliberately too short so an unedited copy fails that guard rather than
# running with a publicly known key.
# Generate one:  python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=CHANGE_ME

# Host port the API is published on (the container always listens on 8000).
API_PORT=8000

# Tag applied to the locally built image.
IMAGE_TAG=local

# Reverse-proxy trust for X-Forwarded-For (ADR 0021). Leave empty when the
# API is reached directly. Behind a load balancer set it to the LB's IP/CIDR
# ranges (or "*" only if the LB is the sole ingress) so per-IP auth rate
# limiting sees the real client IP instead of the proxy's.
FORWARDED_ALLOW_IPS=

# --- Optional: cloud model + tracing (off by default, local-first) ----------
# USE_CLOUD_MODEL=false
# ANTHROPIC_API_KEY=
# From inside a container, host Ollama is not on localhost. On Docker Desktop
# use host.docker.internal; on Linux use the host gateway IP.
# OLLAMA_BASE_URL=http://host.docker.internal:11434
