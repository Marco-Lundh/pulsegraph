# PulseGraph configuration (ADR 0009).
# Copy to .env and fill in. .env is never committed.
#
# The defaults below run the whole system LOCALLY with no cloud
# dependencies and no API keys required.

# --- Core ---
PULSEGRAPH_ENV=local

# --- Database (local Docker, see docker-compose.yml) ---
DATABASE_URL=postgresql+psycopg://pulsegraph:pulsegraph@localhost:5432/pulsegraph

# --- Task queue (local Docker) ---
REDIS_URL=redis://localhost:6379/0

# --- Local model (ADR 0002) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_TIMEOUT_SECONDS=60

# --- Cloud model (ADR 0002) — optional, off by default ---
# Set to true and provide a key to enable Claude fallback for
# complex/critical tasks. When false the system runs 100% locally.
USE_CLOUD_MODEL=false
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# --- Observability (ADR 0007) — optional, off by default ---
# Set ENABLED=true and provide a key to trace each pipeline run to
# LangSmith; the trace id is stored on the run for the dashboard to link.
LANGSMITH_ENABLED=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=pulsegraph

# --- Graph state checkpointing (ADR 0001) — optional, off by default ---
# "none" runs the graph with no checkpointer (default); "memory" keeps
# per-process checkpoints (dev/debug); "postgres" persists every run's graph
# state durably (survives a restart, inspectable/replayable by run id). The
# Postgres saver creates its own checkpoint tables via setup(), not Alembic.
CHECKPOINTER_BACKEND=none
CHECKPOINTER_POOL_SIZE=4

# --- Notification delivery (ADR 0016) — optional, off by default ---
# Email: enable and point at an SMTP server. EMAIL_FROM is the sender;
# each user's address comes from their notification settings (falling
# back to their account email).
EMAIL_ENABLED=false
EMAIL_FROM=alerts@pulsegraph.local
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
# Webhook: enable to POST a JSON payload to each user's configured URL.
# Set a secret to sign the body with an X-PulseGraph-Signature header.
WEBHOOK_ENABLED=false
WEBHOOK_SIGNING_SECRET=

# --- Data sources (ADR 0004) ---
# ENTSO-E Transparency Platform needs a free security token; without it
# the JobTech and Riksdagen sources still work.
ENTSOE_API_TOKEN=
ENTSOE_BASE_URL=https://web-api.tp.entsoe.eu/api

# --- Development conveniences (ADR 0019) ---
# Serve source plugins from recorded fixtures instead of live APIs,
# so the pipeline runs fully offline.
USE_RECORDED_FIXTURES=false

# --- Rate limits and cost cap (ADR 0008) ---
MAX_ACTIVE_WATCHES_PER_USER=20
MAX_RUNS_PER_HOUR_PER_USER=60
# Brute-force protection for the auth endpoints (ADR 0021): attempts per
# window per client IP before login/register return 429 (independent budgets).
AUTH_RATE_LIMIT=10
AUTH_RATE_WINDOW_SECONDS=300
# Worker retry policy (ADR 0015): arq attempts a watch's job this many times
# (with backoff) before the watch is deactivated so it stops being scheduled.
WORKER_MAX_TRIES=3
# Embedding versioning (ADR 0014): items the daily re-embed cron re-embeds
# per run after the embedding model changes, and the cosine similarity (0-1)
# above which a same-model item counts as a semantic duplicate (suppressed,
# not re-notified). 1.0 effectively disables semantic dedup.
REEMBED_BATCH_SIZE=200
EMBEDDING_SIMILARITY_THRESHOLD=0.95
MONTHLY_COST_CAP_USD=10.0
# Operator alerts (ADR 0020): /admin/ops flags spend as near-cap once it
# reaches this fraction of the monthly cap, the queue as backlogged once
# this many jobs are waiting, and runs as slow once p95 exceeds this many
# seconds. Set OPERATOR_WEBHOOK_URL to push firing alerts every 15 min
# (signed when a secret is set); leave blank to poll /admin/ops instead.
# Each alert kind is throttled: once pushed, it is suppressed for
# ALERT_THROTTLE_SECONDS instead of re-sending on every sweep the
# condition stays firing (a kind that resolves and later recurs alerts
# immediately, it is not held back by a stale window).
COST_ALERT_THRESHOLD_RATIO=0.8
QUEUE_BACKLOG_ALERT_THRESHOLD=100
JOB_LATENCY_ALERT_SECONDS=300
OPERATOR_WEBHOOK_URL=
OPERATOR_WEBHOOK_SECRET=
ALERT_THROTTLE_SECONDS=3600

# --- Offline eval release gate (ADR 0012) ---
# Minimum notify-F1 a release must score on the golden datasets; the CI
# gate (scripts/offline_eval.py) fails the build below this.
EVAL_MIN_F1=0.7

# --- Data retention (ADR 0018) ---
# Fetched items (and their analysis/evaluation/notification chain) and
# pipeline-run traces are purged once older than this many days. A daily
# scheduled job enforces it.
DATA_RETENTION_DAYS=90

# --- Digest delivery retry cap (ADR 0016) ---
# A daily-digest notification is retried once per day on push failure;
# after this many total failed attempts it is dead-lettered (status
# FAILED) instead of retrying forever against a permanently broken
# destination.
DIGEST_MAX_ATTEMPTS=5
