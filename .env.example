# PulseGraph configuration (ADR 0009).
# Copy to .env and fill in. .env is never committed.
#
# The defaults below run the whole system LOCALLY with no cloud
# dependencies and no API keys required.

# --- Core ---
PULSEGRAPH_ENV=local

# --- Database (local Docker, see docker-compose.yml) ---
DATABASE_URL=postgresql+psycopg://pulsegraph:pulsegraph@localhost:5432/pulsegraph

# --- Task queue (local Docker) ---
REDIS_URL=redis://localhost:6379/0

# --- Local model (ADR 0002) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# --- Cloud model (ADR 0002) — optional, off by default ---
# Set to true and provide a key to enable Claude fallback for
# complex/critical tasks. When false the system runs 100% locally.
USE_CLOUD_MODEL=false
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# --- Observability (ADR 0007) — optional, off by default ---
LANGSMITH_ENABLED=false
LANGSMITH_API_KEY=

# --- Development conveniences (ADR 0019) ---
# Serve source plugins from recorded fixtures instead of live APIs,
# so the pipeline runs fully offline.
USE_RECORDED_FIXTURES=false

# --- Rate limits and cost cap (ADR 0008) ---
MAX_ACTIVE_WATCHES_PER_USER=20
MAX_RUNS_PER_HOUR_PER_USER=60
MONTHLY_COST_CAP_USD=10.0
